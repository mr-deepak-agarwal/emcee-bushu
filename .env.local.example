# Resend (https://resend.com) — required for the booking form to send emails
RESEND_API_KEY=re_your_api_key_here

# Email that receives new booking enquiries
OWNER_EMAIL=bookings@emceebushu.com

# Verified sender on your Resend domain. Until a custom domain is verified
# in Resend, you can use onboarding@resend.dev for testing only.
FROM_EMAIL="Emcee Bushu Website <onboarding@resend.dev>"
